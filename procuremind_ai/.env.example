# ProcureMind AI Environment Variables

# FLASK SERVER
PORT=8000
HOST=127.0.0.1
FLASK_ENV=development

# AI PROVIDERS (LLM)
# Select which provider to use by default in the backend
LLM_PROVIDER=openai # Options: openai, gemini

# Place your API keys here
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=AIzaSy-your-gemini-api-key-here

# APPLICATION SETTINGS
TOLERANCE_PERCENTAGE=0.02 # 2% tolerance for math validation
